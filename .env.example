# =================================================================
# SoulSeer Environment Variables
# Copy this file to .env (server) and .env (client) and fill in values
# =================================================================

# ── Client (Vite) ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_FACEBOOK_GROUP_URL=
VITE_DISCORD_URL=

# ── Server ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase (replaces Neon + Auth0)
DATABASE_URL=postgresql://postgres:[password]@[project].supabase.co:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=reader-images

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Cloudflare Realtime (replaces Agora)
# Get these from Cloudflare Dashboard > Calls
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CALLS_APP_ID=
CLOUDFLARE_CALLS_APP_SECRET=

# File Storage (for reader profile images uploaded by admin)
# Choose one: Cloudinary or S3
CLOUDINARY_URL=
# or
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
